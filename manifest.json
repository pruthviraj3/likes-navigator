{
  "manifest_version": 3,
  "name": "Instagram Likes Navigator",
  "version": "0.1.0",
  "description": "Extract liked Instagram posts from the activity page and navigate saved items in-page.",
  "permissions": [
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.fbcdn.net/*",
    "https://*.cdninstagram.com/*"
  ],
  "background": {
    "service_worker": "build/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "build/page-bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "build/content-script.js"
      ],
      "run_at": "document_start"
    }
  ]
}
